Screen {
    align: center middle;
}
#combo-container {
    border: solid blue;
    background: yellow 50%;
    align: center middle;
}
Horizontal {
    align: center middle;
    height: auto;
}

#buttons {
    layout: horizontal;
    border: solid blue;
    align: center middle;
}

#msg-container {
    width:100%;
    height:80%;
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-size-vertical: 1;
}

#ok {
    margin: 0 0 0 0;
}

RadioSet {
    layout: horizontal;
    width: 50%;
}